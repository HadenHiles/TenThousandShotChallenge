rules_version = '2';

// Firebase Storage Rules for Ten Thousand Shot Challenge
service firebase.storage {
  match /b/{bucket}/o {
    // Allow users to upload and read their own avatar images
    match /avatars/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow public read access to default avatars
    match /public/avatars/{allPaths=**} {
      allow read;
    }
    
    // Allow users to upload session videos/images (if implemented in the future)
    match /sessions/{userId}/{sessionId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Public assets (team logos, etc.)
    match /public/{allPaths=**} {
      allow read;
    }

    // Challenge coaching media (videos, images used in Challenger Road steps).
    // These are non-sensitive coaching assets that all users need to play back.
    // Public read is required because the video_player HTTP client (fvp/libmdk
    // on Android) sends plain HTTPS requests with no Firebase auth header, so
    // request.auth is always null for video playback requests.
    // Files are stored under two top-level paths depending on upload batch.
    match /media/{allPaths=**} {
      allow read;
    }
    match /challenges/{allPaths=**} {
      allow read;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
