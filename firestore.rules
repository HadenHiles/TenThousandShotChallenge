rules_version = '2';
// Reference copy — deploy from the Flutter app repo:
//   firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper ────────────────────────────────────────────────────────────────
    function isContentAdmin() {
      return request.auth != null && request.auth.token.isContentAdmin == true;
    }

    match /users {
      allow read, create: if request.auth != null

      match /{userId}/{document=**} {
        allow read: if request.auth != null
        allow write, delete: if request.auth.uid == userId;

        match /claims {
          allow read: if request.auth.uid == resource.data.app_user_id
        }

        match /achievements {
          allow read: if request.auth != null
          allow write, delete: if request.auth.uid == userId

          match /{achievementId} {
            allow read: if request.auth != null
            allow write, delete: if request.auth != null && request.auth.uid == userId;
          }
        }

        match /stats {
          allow read: if request.auth != null
          allow write, delete: if request.auth.uid == userId
        }

        match /meta {
          allow read: if request.auth != null
          allow write, delete: if request.auth.uid == userId
        }
      }
    }
    match /iterations {
      allow read, create: if request.auth != null

      match /{userId} {
        allow read: if request.auth != null

        match /{document=**} {
          allow read: if request.auth != null
          allow write: if request.auth.uid == userId
        }

        match /iterations {
          match /{document=**} {
            allow read: if request.auth != null
          }

          match /sessions/{document=**} {
            allow read: if request.auth != null
          }
        }
      }
    }
    match /teams {
      allow read, create: if request.auth != null

      match /{document=**} {
        allow read, write, update, create: if request.auth != null
      }
    }
    match /teammates {
      allow read, create: if request.auth != null

      match /{userId} {
        allow read: if request.auth != null

        match /{document=**} {
          allow read, write: if request.auth != null
        }

        match /teammates {
          match /{document=**} {
            allow read: if request.auth != null
          }
        }
      }
    }
    match /invites {
      allow read, create: if request.auth != null

      match /{userId} {
        allow read: if request.auth != null

        match /{document=**} {
          allow read, write: if request.auth != null
        }

        match /invites {
          match /{document=**} {
            allow read: if request.auth != null
          }
        }
      }
    }
    match /merch/{document=**} {
      allow read: if request.auth != null;
      allow write, delete: if isContentAdmin();
    }
    match /trainingPrograms/{document=**} {
      allow read: if request.auth != null;
      allow write, delete: if isContentAdmin();
    }
    match /learn_to_play/{document=**} {
      allow read: if request.auth != null;
      allow write, delete: if isContentAdmin();
    }
    match /learn_videos/{document=**} {
      allow read: if request.auth != null;
      allow write, delete: if isContentAdmin();
    }

    // ── Challenger Road ────────────────────────────────────────────────────────
    match /challenger_road_levels/{levelId} {
      allow read: if request.auth != null;
      allow write, delete: if isContentAdmin();

      match /challenges/{challengeId} {
        allow read: if request.auth != null;
        allow write, delete: if isContentAdmin();
      }
    }

    // Challenger Road Badges — read by all authenticated users (Flutter app
    // displays badges); write/delete restricted to content admins (admin UI).
    match /challenger_road_badges/{badgeId} {
      allow read: if request.auth != null;
      allow write, delete: if isContentAdmin();
    }

    // Per-user Challenger Road state — owner read/write only.
    match /users/{userId}/challenger_road/{docId} {
      allow read, write: if request.auth.uid == userId;
    }
    match /users/{userId}/challenger_road_attempts/{attemptId} {
      allow read, write: if request.auth.uid == userId;

      match /challenge_sessions/{sessionId} {
        allow read, write: if request.auth.uid == userId;
      }

      match /challenge_progress/{challengeId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    match /users/{userId}/challenger_road_challenge_history/{challengeId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
