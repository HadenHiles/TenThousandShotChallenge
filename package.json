{
    "name": "ten-thousand-shot-challenge",
    "version": "1.0.0",
    "private": true,
    "description": "Test and dev tools for Ten Thousand Shot Challenge",
    "scripts": {
        "seed:firestore": "firestore-seed --emulatorHost localhost:8080 --project demo-project",
        "seed:challenger-road": "node scripts/seed_challenger_road.js",
        "unseed:challenger-road": "node scripts/unseed_challenger_road.js",
        "seed:challenger-road:emulator": "FIRESTORE_EMULATOR_HOST=localhost:8080 node scripts/seed_challenger_road.js",
        "unseed:challenger-road:emulator": "FIRESTORE_EMULATOR_HOST=localhost:8080 node scripts/unseed_challenger_road.js"
    },
    "dependencies": {
        "firebase-admin": "^13.4.0",
        "firebase-functions": "^6.3.2",
        "firestore-seed": "^0.0.11"
    },
    "firestore-seed": {
        "databaseURL": "http://localhost:9000?ns=demo-project",
        "collections": [
            {
                "name": "users",
                "data": "test/test_data/users.json"
            },
            {
                "name": "teams",
                "data": "test/test_data/teams.json"
            },
            {
                "name": "iterations",
                "data": "test/test_data/iterations.json"
            },
            {
                "name": "invites",
                "data": "test/test_data/invites.json"
            }
        ]
    }
}